# VISTA — copy to .env and fill in. Never commit .env.
# Everything runs with ZERO keys on the mock backend (the default).

# Backend selector: mock | live  (per-client override: NEBIUS_BACKEND, MEM0_BACKEND, ...)
VISTA_BACKEND=mock

# Nebius Token Factory (sponsor code: BUILDER-SHIP-HACK) — all agent inference
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# mem0 (sponsor code: SHIPBUILDERS) — personalization/memory layer
MEM0_API_KEY=

# Tavily (sponsor code: TVLY-7CCN692Z) — one-time listing discovery
TAVILY_API_KEY=

# Composio (sponsor code: SHIP_BUILDERS) — mood-board import
COMPOSIO_API_KEY=
