# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
#
#   cp .env.example .env
#
# Buildship loads these at startup (main.py / buildship.adapters).

# === Nebius AI Studio — codegen (OpenAI-compatible) ===
# Get a key: https://studio.nebius.ai/
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1
# Low-temp coder model; DeepSeek-V3 or a large Qwen per the build plan.
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3

# === Tavily — API research / web search step ===
# Get a key: https://app.tavily.com/
TAVILY_API_KEY=

# === Composio — sandbox execution + real actions ===
# Get a key: https://app.composio.dev/
COMPOSIO_API_KEY=
# Stable user/session id for the tool-router session and action execution.
COMPOSIO_USER_ID=buildship

# === Buildship harness config ===
# Max self-correction retries before a tool build is abandoned (build budget).
BUILDSHIP_MAX_BUILD_ATTEMPTS=3
# Codegen sampling temperature — keep low for reliable tools.
BUILDSHIP_CODEGEN_TEMPERATURE=0.1
# Tavily results to summarize into the research snippet.
BUILDSHIP_SEARCH_MAX_RESULTS=5
# Where built charts are written (also the auto-upload allowlist for Composio).
BUILDSHIP_ARTIFACT_DIR=artifacts
# Persistent tool library (JSON).
BUILDSHIP_LIBRARY=buildship_library.json

# === Sandbox backend ===
# composio = run tool source in Composio's remote workbench (default).
# local    = run in a local subprocess (validates the loop before Composio is wired).
BUILDSHIP_SANDBOX=composio
# Composio workbench compute tier: standard | medium | large | xlarge.
BUILDSHIP_SANDBOX_SIZE=standard
# Backend-defined argument key for COMPOSIO_REMOTE_WORKBENCH source. If a live run
# errors at the sandbox step, try "source" instead of "code".
BUILDSHIP_WORKBENCH_ARG=code
# Timeout (seconds) for the local subprocess sandbox.
BUILDSHIP_SANDBOX_TIMEOUT=60

# === Real action (post the chart to Slack) ===
# 1. Connect a Slack account to your Composio project (one-time), from a terminal
#    with network (the v3 way; toolkits.authorize/connected_accounts.initiate are
#    deprecated for managed OAuth):
#      from composio import Composio
#      c = Composio(api_key="...")
#      req = c.connected_accounts.link(user_id="buildship", auth_config_id="<slack auth config>")
#      print(req.redirect_url)    # open it, authorize Slack
#      req.wait_for_connection()  # connection becomes ACTIVE
#    (Create the Slack auth config in the dashboard at app.composio.dev, or via
#     c.auth_configs.create. With exactly one ACTIVE Slack connection, user_id
#     alone resolves it at execute time.)
# 2. Confirm the exact slugs/arg keys for YOUR account (slugs can change):
#      c.tools.get_raw_composio_tools(toolkits=["SLACK"])  # inspect slug + input_parameters
#
# --- text-only message (default; reliably fires, does NOT attach the PNG) ---
BUILDSHIP_ACTION_SLUG=SLACK_SENDS_A_MESSAGE_TO_A_CHANNEL
BUILDSHIP_ACTION_CHANNEL_ARG=channel
BUILDSHIP_ACTION_TEXT_ARG=text
BUILDSHIP_ACTION_FILE_ARG=
# --- to ATTACH the chart: one send-message call can't carry a file, so switch to
#     the upload action and set the file + caption args:
#       BUILDSHIP_ACTION_SLUG=SLACK_UPLOAD_FILE       # older accounts: SLACK_UPLOADS_A_FILE
#       BUILDSHIP_ACTION_FILE_ARG=file
#       BUILDSHIP_ACTION_TEXT_ARG=initial_comment     # caption arg on the upload action
#
BUILDSHIP_SLACK_CHANNEL=
# Optional: pin a connected account; needed only if the user has multiple active Slack connections.
COMPOSIO_CONNECTED_ACCOUNT_ID=
